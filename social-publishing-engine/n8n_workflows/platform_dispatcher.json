{
  "name": "Tier 2: Platform Dispatcher & 72-Minute Queue",
  "nodes": [
    {
      "parameters": {},
      "name": "Start / Trigger from Tier 1",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "name": "Split Ingested Tracks 1 by 1",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "functionCode": "const item = $input.item.json;\nconst brandId = item.brand_id || 'phonk_pipeline';\n\n// Determine active platforms based on brand\nconst brandTargets = {\n  phonk_pipeline: ['youtube', 'instagram', 'facebook', 'tiktok', 'routenote'],\n  publixion: ['youtube', 'linkedin', 'instagram', 'facebook'],\n  myfitnessleap: ['youtube', 'instagram', 'tiktok', 'linkedin'],\n  neurostackos: ['youtube', 'tiktok', 'linkedin']\n};\n\nconst targets = brandTargets[brandId] || brandTargets.phonk_pipeline;\n\nreturn [{\n  json: {\n    ...item,\n    active_targets: targets\n  }\n}];"
      },
      "name": "Resolve Active Brand Targets",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json[\"active_targets\"].includes('youtube') }}",
              "value2": "true"
            }
          ]
        }
      },
      "name": "Check YouTube Enabled",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [900, 180]
    },
    {
      "parameters": {
        "workflowId": "executor_youtube_id"
      },
      "name": "Execute YouTube Upload",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [1120, 100]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json[\"active_targets\"].includes('tiktok') }}",
              "value2": "true"
            }
          ]
        }
      },
      "name": "Check TikTok Enabled",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "command": "docker exec -i social-browser-engine-1 python /app/tiktok_uploader.py --brand \"${$json[\"brand_id\"]}\" --file \"${$json[\"video_path\"]}\" --caption \"${$json[\"normalized_captions\"][\"tiktok\"]}\""
      },
      "name": "Execute TikTok Bot (Playwright)",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json[\"active_targets\"].includes('routenote') }}",
              "value2": "true"
            }
          ]
        }
      },
      "name": "Check RouteNote Enabled",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [900, 420]
    },
    {
      "parameters": {
        "command": "docker exec -i social-browser-engine-1 python /app/routenote_uploader.py --audio \"${$json[\"audio_path\"]}\" --cover \"${$json[\"cover_path\"]}\" --title \"${$json[\"slug\"]}\" --artist \"Antigravity Phonk\""
      },
      "name": "Execute RouteNote $0 Bot",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1120, 420]
    },
    {
      "parameters": {
        "amount": 72,
        "unit": "minutes"
      },
      "name": "72-Minute Algorithmic Drip Wait",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1360, 300]
    }
  ],
